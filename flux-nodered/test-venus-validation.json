  {
    "id": "fn_hp_on",
    "type": "function",
    "z": "tab_heatpump",
    "name": "Payload Heatpump ON",
    "func": "// com.victronenergy.heatpump — State values :\n// 0=Standby, 1=On/Idle, 2=Heating, 3=Cooling, 4=Hot water, 5=Defrost\nmsg.payload = {\n    \"State\": 2,\n    \"Temperature\": 52.5,\n    \"TargetTemperature\": 55.0,\n    \"Ac\": {\n        \"Power\": 1200.0,\n        \"Energy\": {\n            \"Forward\": 145.3\n        }\n    },\n    \"Position\": 0\n};\nreturn msg;",
    "outputs": 1,
    "x": 460,
    "y": 100,
    "wires": [["mqtt_hp_out", "dbg_hp"]]
  },
  {
    "id": "fn_hp_off",
    "type": "function",
    "z": "tab_heatpump",
    "name": "Payload Heatpump OFF",
    "func": "msg.payload = {\n    \"State\": 0,\n    \"Temperature\": 48.0,\n    \"TargetTemperature\": 55.0,\n    \"Ac\": {\n        \"Power\": 0.0,\n        \"Energy\": {\n            \"Forward\": 145.3\n        }\n    },\n    \"Position\": 0\n};\nreturn msg;",
    "outputs": 1,
    "x": 460,
    "y": 160,
    "wires": [["mqtt_hp_out", "dbg_hp"]]
  },
