    "id": "fn_plt_running",
    "type": "function",
    "z": "tab_platform",
    "name": "Platform Backup running",
    "func": "msg.payload = {\n    \"Backup\": {\n        \"Status\": 1,\n        \"LastRun\": Math.floor(Date.now() / 1000)\n    },\n    \"Restore\": {\n        \"Status\": 0,\n        \"LastRun\": 0\n    }\n};\nreturn msg;",
    "outputs": 1,
    "x": 460,
