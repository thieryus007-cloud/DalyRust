  {
    "id": "tab_meteo_test",
    "type": "tab",
    "label": "⚠️ TEST Meteo (SUPPRIMER demain)",
    "disabled": false,
    "info": "Flow TEMPORAIRE — simulation capteur irradiance RS485.\nSupprimer quand le vrai capteur sera connecté.\nVérifier D-Bus : ssh root@192.168.1.120 'dbus -y com.victronenergy.meteo /Irradiance GetValue'"
  },
  {
    "id": "inj_meteo_auto",
    "type": "inject",
    "z": "tab_meteo_test",
    "name": "Simuler irradiance toutes les 30s",
    "props": [{ "p": "payload" }],
    "repeat": "30",
    "crontab": "",
    "once": true,
    "onceDelay": 1,
    "topic": "",
    "payload": "",
    "payloadType": "date",
    "x": 200,
    "y": 100,
    "wires": [["fn_meteo_payload"]]
  },
  {
    "id": "inj_meteo_nuit",
    "type": "inject",
    "z": "tab_meteo_test",
    "name": "Forcer nuit (0 W/m²)",
    "props": [{ "p": "payload", "v": "0", "vt": "num" }],
    "repeat": "",
    "crontab": "",
    "once": false,
    "topic": "",
    "x": 180,
    "y": 160,
    "wires": [["fn_meteo_nuit"]]
  },
  {
    "id": "fn_meteo_payload",
    "type": "function",
    "z": "tab_meteo_test",
    "name": "Payload Meteo simulé",
    "func": "// SIMULATION — remplacer par vraie lecture RS485 demain\nvar h = new Date().getHours();\nvar irr = 0;\nif (h >= 7 && h <= 19) {\n    // Courbe sinusoïdale entre 7h et 19h, max midi\n    var t = (h - 7) / 12.0;\n    irr = Math.round(1000 * Math.sin(t * Math.PI));\n}\nmsg.payload = {\n    \"Irradiance\": Math.max(0, irr),\n    \"TodaysYield\": parseFloat((irr * 0.004).toFixed(2))\n};\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "x": 460,
    "y": 100,
    "wires": [["mqtt_meteo_out", "dbg_meteo"]]
  },
  {
    "id": "fn_meteo_nuit",
    "type": "function",
    "z": "tab_meteo_test",
    "name": "Meteo nuit",
    "func": "msg.payload = { \"Irradiance\": 0, \"TodaysYield\": 0 };\nreturn msg;",
    "outputs": 1,
    "x": 460,
    "y": 160,
    "wires": [["mqtt_meteo_out", "dbg_meteo"]]
  },
  {
    "id": "mqtt_meteo_out",
    "type": "mqtt out",
    "z": "tab_meteo_test",
    "name": "→ santuario/meteo/venus",
    "topic": "santuario/meteo/venus",
    "qos": "0",
    "retain": "true",
    "broker": "broker_nanopi_venus",
    "x": 700,
    "y": 100,
    "wires": []
  },
  {
    "id": "dbg_meteo",
    "type": "debug",
    "z": "tab_meteo_test",
    "name": "Meteo publié",
    "active": true,
    "tosidebar": true,
    "console": false,
    "tostatus": true,
    "complete": "payload",
    "targetType": "msg",
    "x": 700,
    "y": 160,
    "wires": []
  },
  {
    "id": "txt_meteo_info",
    "type": "comment",
    "z": "tab_meteo_test",
    "name": "Vérification D-Bus après 1ère publication",
    "info": "ssh root@192.168.1.120\ndbus -y | grep meteo\ndbus -y com.victronenergy.meteo /Irradiance GetValue\ndbus -y com.victronenergy.meteo /TodaysYield GetValue",
