  {
    "id": "fn_plt_ok",
    "type": "function",
    "z": "tab_platform",
    "name": "Platform Backup OK",
    "func": "// Status : 0=idle, 1=running, 2=OK, 3=error\n// LastRun : timestamp Unix secondes\nmsg.payload = {\n    \"Backup\": {\n        \"Status\": 2,\n        \"LastRun\": Math.floor(Date.now() / 1000)\n    },\n    \"Restore\": {\n        \"Status\": 0,\n        \"LastRun\": 0\n    }\n};\nreturn msg;",
    "outputs": 1,
    "x": 450,
    "y": 100,
    "wires": [["mqtt_plt_out", "dbg_plt"]]
  },
