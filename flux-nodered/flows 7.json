        "z": "f1af1add6c9f4e7f",
        "name": "Republier depuis contexte",
        "func": "const temp = global.get('outdoor_temp');\nconst humidity = global.get('outdoor_humidity');\n\n// Attendre la première récupération Open-Meteo\nif (temp === undefined || temp === null) {\n    return null;\n}\n\nreturn {\n    topic: 'santuario/heat/1/venus',\n    payload: JSON.stringify({\n        Temperature: temp,\n        Humidity: humidity\n    })\n};",
