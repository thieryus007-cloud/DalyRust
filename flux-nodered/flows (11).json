    {
        "id": "swh_http_get",
        "type": "http request",
        "z": "eca20a68bef0de32",
        "name": "GET /state LG ThinQ",
        "method": "GET",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 570,
