    {
        "id": "swh_comment_keepalive",
        "type": "comment",
        "z": "eca20a68bef0de32",
        "name": "Keepalive 25s (obligatoire : watchdog Rust = 30s — sinon /Connected = 0)",
        "info": "Le service dbus-mqtt-venus surveille l'activité MQTT.\nSi aucun message n'arrive pendant 30s (watchdog_sec), /Connected passe à 0\net le device disparaît du VRM. Ce keepalive republie le dernier état connu\ndepuis le contexte global toutes les 25s.",
        "x": 270,
        "y": 300,
        "wires": []
    },
    {
        "id": "swh_inject_keepalive",
        "type": "inject",
        "z": "eca20a68bef0de32",
        "name": "Keepalive 25s",
        "props": [],
        "repeat": "25",
        "crontab": "",
        "once": false,
        "onceDelay": "",
        "topic": "",
        "x": 150,
