    {
        "id": "37fd5c5a52a45217",
        "type": "function",
        "z": "f9c19fc3b4cd942b",
        "name": "Calculate PV excess",
        "func": "let pvPower = flow.get('pvPower') || 0;\nlet consumption = flow.get('consumption') || 0;\n\nif (msg.topic === '/Ac/PvOnOutput/L1/Power' || msg.hasOwnProperty('service') && msg.path === '/Ac/PvOnOutput/L1/Power') {\n    pvPower = msg.payload || 0;\n    flow.set('pvPower', pvPower);\n} else if (msg.topic === '/Ac/ConsumptionOnOutput/L1/Power' || msg.hasOwnProperty('service') && msg.path === '/Ac/ConsumptionOnOutput/L1/Power') {\n    consumption = msg.payload || 0;\n    flow.set('consumption', consumption);\n}\n\nlet excess = pvPower - consumption;\nlet pvExcess = excess > 50;\n\nflow.set('pvExcess', pvExcess);\n\nnode.status({\n    fill: pvExcess ? \"green\" : \"grey\",\n    shape: \"dot\",\n    text: `PV: ${pvPower}W | Cons: ${consumption}W | Excess: ${excess}W | Flag: ${pvExcess}`\n});\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
        "y": 540,
        "wires": [
            []
        ]
    },
    {
        "id": "c6153ca324cb499a",
        "type": "comment",
        "z": "f9c19fc3b4cd942b",
        "name": "Le système fonctionne ainsi...",
        "info": "\n\nQuand Grid connecté + excédent PV > 50W → 4A (absorbe l'excédent dans les batteries)\nQuand Grid connecté + pas d'excédent → 0A (pas de charge depuis le Grid)\nQuand Grid déconnecté → 70A (charge maximale)",
        "x": 660,
        "y": 620,
        "wires": []
    },
