    {
        "id": "fn-parse-state-51",
        "type": "function",
        "z": "b6e8da280e925b95",
        "name": "Parser état SW51",
        "func": "var raw = msg.payload;\nvar val = (raw && raw.value !== undefined) ? raw.value : raw;\nvar label = (val == 1) ? 'ON ✅' : (val == 0) ? 'OFF ❌' : 'INCONNU (?)';\nflow.set('sw51_state', val);\nmsg.payload = { instance: 51, etat: label, valeur: val, raw: raw };\nmsg.topic = 'SW51';\nreturn msg;",
