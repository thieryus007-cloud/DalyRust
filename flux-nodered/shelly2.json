    {
        "id": "fn-log-state",
        "type": "function",
        "z": "b6e8da280e925b95",
        "name": "Log combiné SW50+SW51",
        "func": "var sw50 = flow.get('sw50_state');\nvar sw51 = flow.get('sw51_state');\nvar fmt = function(v) { return (v == 1) ? 'ON' : (v == 0) ? 'OFF' : '?'; };\nmsg.payload = 'SW50=' + fmt(sw50) + '  |  SW51=' + fmt(sw51);\nreturn msg;",
        "outputs": 1,
